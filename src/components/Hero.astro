---
import { getHero } from '../content/site/hero';
import { siteContext } from '../lib/runtime';
const { db, opts } = siteContext(Astro);
const hero = await getHero(db, opts);
---

<section id="top" class="relative flex min-h-[100svh] items-center justify-center overflow-hidden">
  <!--
    Background video. Goldstar has no footage yet, so the poster (a real project
    photo) shows until /public/video/hero.{webm,mp4} are added. prefers-reduced-motion
    users never get the autoplay — the poster image carries the hero. (BRIEF §10)
  -->
  <video
    class="absolute inset-0 h-full w-full object-cover motion-reduce:hidden"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    poster={hero.poster}
    aria-hidden="true"
  >
    {hero.videoSources.map((s) => <source src={s.src} type={s.type} />)}
  </video>

  <!-- Poster fallback for reduced-motion users (and before the video loads) -->
  <img
    src={hero.poster}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 hidden h-full w-full object-cover motion-reduce:block"
  />

  <!-- Legibility overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-brand-green-700/55 via-black/45 to-black/65"></div>

  <div class="relative z-10 mx-auto max-w-4xl px-6 py-28 text-center text-white">
    <h1 class="font-heading text-4xl font-extrabold leading-tight drop-shadow-md sm:text-5xl md:text-6xl">
      {hero.headline}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-white/90 drop-shadow sm:text-lg">
      {hero.subhead}
    </p>
    <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href={hero.primaryCta.href}
        class="w-full rounded-full bg-brand-gold px-7 py-3.5 text-base font-bold text-brand-green-700 shadow-lg transition hover:bg-brand-gold-300 sm:w-auto"
      >
        {hero.primaryCta.label}
      </a>
      <a
        href={hero.secondaryCta.href}
        class="w-full rounded-full border-2 border-white/80 px-7 py-3.5 text-base font-bold text-white transition hover:bg-white hover:text-brand-green-700 sm:w-auto"
      >
        {hero.secondaryCta.label}
      </a>
    </div>
  </div>

  <!-- Scroll hint -->
  <a
    href="#services"
    aria-label="Scroll to services"
    class="absolute bottom-6 left-1/2 z-10 -translate-x-1/2 text-white/80 transition hover:text-white"
  >
    <span class="block animate-bounce text-2xl" aria-hidden="true">⌄</span>
  </a>
</section>
