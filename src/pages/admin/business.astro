---
import Admin from '../../layouts/Admin.astro';
import { getBusiness, type Business } from '../../content/site/business';
import { getDB } from '../../lib/cf';
import { saveDraft, publish } from '../../lib/db';
import { str, num, lines, pipePairs } from '../../lib/editor';

const db = getDB();

if (Astro.request.method === 'POST' && db) {
  const form = await Astro.request.formData();
  const action = String(form.get('action') || 'save');
  const data: Business = {
    name: str(form, 'name'),
    tagline: str(form, 'tagline'),
    phoneDisplay: str(form, 'phoneDisplay'),
    phoneHref: str(form, 'phoneHref'),
    email: str(form, 'email'),
    yearsInBusiness: str(form, 'yearsInBusiness'),
    baseCity: str(form, 'baseCity'),
    serviceArea: lines(form.get('serviceArea')),
    hours: str(form, 'hours'),
    rating: {
      value: num(form, 'ratingValue'),
      count: num(form, 'ratingCount'),
      source: str(form, 'ratingSource'),
      sourceHref: str(form, 'ratingHref'),
    },
    socials: pipePairs(form.get('socials')).map((p) => ({ label: p.a, href: p.b })),
    logo: str(form, 'logo'),
  };
  await saveDraft(db, 'business', data);
  if (action === 'publish') await publish(db, 'business');
  return Astro.redirect(`/admin/business?${action === 'publish' ? 'published' : 'saved'}=1`);
}

const b = await getBusiness(db, { preview: true });
const saved = Astro.url.searchParams.has('saved');
const published = Astro.url.searchParams.has('published');
const fieldCls = 'rounded-lg border border-black/10 bg-white px-3 py-2.5 text-sm';
---

<Admin title="Edit Business info — Goldstar Admin">
  <a href="/admin" class="text-sm font-semibold text-brand-green hover:text-brand-gold">← Dashboard</a>
  <h1 class="mt-2 font-heading text-2xl font-extrabold text-brand-green">Business info</h1>

  {(saved || published) && (
    <p class="mt-4 rounded-lg bg-green-50 px-4 py-2 text-sm font-medium text-green-800 ring-1 ring-green-200">
      {published ? 'Published — live on your site.' : 'Draft saved.'}
    </p>
  )}

  <form method="POST" class="mt-6 grid max-w-2xl gap-5">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="grid gap-1"><span class="text-sm font-semibold">Business name</span>
        <input name="name" value={b.name} class={fieldCls} /></label>
      <label class="grid gap-1"><span class="text-sm font-semibold">Base city</span>
        <input name="baseCity" value={b.baseCity} class={fieldCls} /></label>
    </div>
    <label class="grid gap-1"><span class="text-sm font-semibold">Tagline</span>
      <input name="tagline" value={b.tagline} class={fieldCls} /></label>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="grid gap-1"><span class="text-sm font-semibold">Phone (display)</span>
        <input name="phoneDisplay" value={b.phoneDisplay} class={fieldCls} /></label>
      <label class="grid gap-1"><span class="text-sm font-semibold">Phone link (tel:)</span>
        <input name="phoneHref" value={b.phoneHref} class={fieldCls} /></label>
      <label class="grid gap-1"><span class="text-sm font-semibold">Email</span>
        <input name="email" value={b.email} class={fieldCls} /></label>
      <label class="grid gap-1"><span class="text-sm font-semibold">Years in business</span>
        <input name="yearsInBusiness" value={b.yearsInBusiness} class={fieldCls} /></label>
    </div>
    <label class="grid gap-1"><span class="text-sm font-semibold">Hours</span>
      <input name="hours" value={b.hours} class={fieldCls} /></label>
    <label class="grid gap-1"><span class="text-sm font-semibold">Logo path</span>
      <input name="logo" value={b.logo} class={fieldCls} /></label>

    <label class="grid gap-1">
      <span class="text-sm font-semibold">Service area</span>
      <textarea name="serviceArea" rows="4" class={fieldCls}>{b.serviceArea.join('\n')}</textarea>
      <span class="text-xs text-brand-ink/50">One city per line.</span>
    </label>

    <fieldset class="grid gap-3 rounded-xl border border-black/10 p-4">
      <legend class="px-1 text-xs font-bold uppercase tracking-wide text-brand-ink/50">Rating</legend>
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="grid gap-1"><span class="text-sm font-semibold">Value</span>
          <input name="ratingValue" type="number" step="0.1" value={b.rating.value} class={fieldCls} /></label>
        <label class="grid gap-1"><span class="text-sm font-semibold">Review count</span>
          <input name="ratingCount" type="number" value={b.rating.count} class={fieldCls} /></label>
        <label class="grid gap-1"><span class="text-sm font-semibold">Source</span>
          <input name="ratingSource" value={b.rating.source} class={fieldCls} /></label>
        <label class="grid gap-1"><span class="text-sm font-semibold">Source link</span>
          <input name="ratingHref" value={b.rating.sourceHref} class={fieldCls} /></label>
      </div>
    </fieldset>

    <label class="grid gap-1">
      <span class="text-sm font-semibold">Social links</span>
      <textarea name="socials" rows="4" class={fieldCls}>{b.socials.map((s) => `${s.label} | ${s.href}`).join('\n')}</textarea>
      <span class="text-xs text-brand-ink/50">One per line, format: <code>Label | https://url</code></span>
    </label>

    <div class="flex flex-wrap items-center gap-3 border-t border-black/10 pt-5">
      <button type="submit" name="action" value="save"
        class="rounded-full bg-brand-green px-5 py-2.5 text-sm font-bold text-white hover:bg-brand-green-700">Save draft</button>
      <button type="submit" name="action" value="publish"
        class="rounded-full bg-brand-gold px-5 py-2.5 text-sm font-bold text-brand-green-700 hover:bg-brand-gold-300">Publish</button>
      <a href="/?preview=1" target="_blank" class="text-sm font-semibold text-brand-green hover:text-brand-gold">Preview draft ↗</a>
    </div>
  </form>
</Admin>
