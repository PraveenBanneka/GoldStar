---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { getBusiness } from '../content/site/business';
import { siteContext } from '../lib/runtime';
const { db, opts } = siteContext(Astro);
const business = await getBusiness(db, opts);
const updated = 'June 2026';
---

<Base title={`Privacy Policy | ${business.name}`} description={`Privacy policy for ${business.name}.`}>
  <main class="mx-auto max-w-3xl px-5 py-20 md:px-8">
    <a href="/" class="text-sm font-semibold text-brand-green hover:text-brand-gold">← Back to home</a>
    <h1 class="mt-6 font-heading text-4xl font-extrabold text-brand-green">Privacy Policy</h1>
    <p class="mt-2 text-sm text-brand-ink/50">Last updated: {updated}</p>

    <div class="mt-8 space-y-5 text-base leading-relaxed text-brand-ink/80">
      <p>
        {business.name} (“we”, “us”) respects your privacy. This policy explains what information
        we collect through this website and how we use it. <strong>This is placeholder boilerplate —
        review with a professional before launch.</strong>
      </p>
      <h2 class="font-heading text-xl font-bold text-brand-green">Information we collect</h2>
      <p>
        When you submit our contact form we collect the name, email address, phone number and project
        details you provide, solely to respond to your inquiry and prepare a quote.
      </p>
      <h2 class="font-heading text-xl font-bold text-brand-green">How we use it</h2>
      <p>
        We use your information only to communicate with you about your project. We do not sell your
        personal information.
      </p>
      <h2 class="font-heading text-xl font-bold text-brand-green">Contact</h2>
      <p>
        Questions? Email <a href={`mailto:${business.email}`} class="font-semibold text-brand-green underline underline-offset-2 hover:text-brand-gold">{business.email}</a>
        or call <a href={business.phoneHref} class="font-semibold text-brand-green underline underline-offset-2 hover:text-brand-gold">{business.phoneDisplay}</a>.
      </p>
    </div>
  </main>
  <Footer />
</Base>
