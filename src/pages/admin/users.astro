---
import Admin from '../../layouts/Admin.astro';
import { getDB } from '../../lib/cf';
import { listUsers, createUser, deleteUser, setPassword, countUsers } from '../../lib/auth';
import { str } from '../../lib/editor';

const db = getDB();
const me = Astro.locals.user;
let error = '';

if (Astro.request.method === 'POST' && db) {
  const form = await Astro.request.formData();
  const action = str(form, 'action');

  if (action === 'add') {
    const username = str(form, 'username');
    const password = str(form, 'password');
    if (username.length < 3 || password.length < 8) {
      error = 'Username must be 3+ characters and password 8+ characters.';
    } else {
      try {
        await createUser(db, username, password);
      } catch {
        error = 'That username is already taken.';
      }
    }
  } else if (action.startsWith('delete:')) {
    const id = Number(action.split(':')[1]);
    if (id === me?.id) error = "You can't delete your own account.";
    else if ((await countUsers(db)) <= 1) error = "You can't delete the last account.";
    else await deleteUser(db, id);
  } else if (action.startsWith('setpw:')) {
    const id = Number(action.split(':')[1]);
    const password = str(form, `newpw_${id}`);
    if (password.length < 8) error = 'New password must be 8+ characters.';
    else await setPassword(db, id, password);
  }

  if (!error) return Astro.redirect('/admin/users?ok=1');
}

const users = await listUsers(db);
const ok = Astro.url.searchParams.has('ok');
const fieldCls = 'rounded-lg border border-black/10 bg-white px-3 py-2.5 text-sm';
---

<Admin title="Users — Goldstar Admin">
  <a href="/admin" class="text-sm font-semibold text-brand-green hover:text-brand-gold">← Dashboard</a>
  <h1 class="mt-2 font-heading text-2xl font-extrabold text-brand-green">Users</h1>

  {error && (
    <p class="mt-4 rounded-lg bg-red-50 px-4 py-2 text-sm font-medium text-red-700 ring-1 ring-red-200">{error}</p>
  )}
  {ok && (
    <p class="mt-4 rounded-lg bg-green-50 px-4 py-2 text-sm font-medium text-green-800 ring-1 ring-green-200">Saved.</p>
  )}

  <div class="mt-6 grid gap-4">
    {users.map((u) => (
      <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-black/5">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div class="font-heading font-bold text-brand-green">
            {u.username}
            {u.id === me?.id && <span class="ml-2 text-xs font-semibold text-brand-ink/50">(you)</span>}
          </div>
          <form method="POST" class="inline">
            <button type="submit" name="action" value={`delete:${u.id}`}
              disabled={u.id === me?.id}
              class="rounded border border-red-200 px-3 py-1 text-xs font-semibold text-red-600 hover:bg-red-50 disabled:opacity-30">
              Delete
            </button>
          </form>
        </div>
        <form method="POST" class="mt-3 flex flex-wrap items-end gap-2">
          <label class="grid gap-1">
            <span class="text-xs font-semibold text-brand-ink/60">New password</span>
            <input name={`newpw_${u.id}`} type="password" autocomplete="new-password" class={fieldCls} />
          </label>
          <button type="submit" name="action" value={`setpw:${u.id}`}
            class="rounded-full bg-brand-green px-4 py-2 text-xs font-bold text-white hover:bg-brand-green-700">
            Update password
          </button>
        </form>
      </div>
    ))}
  </div>

  <div class="mt-8 rounded-xl bg-white p-5 shadow-sm ring-1 ring-black/5">
    <h2 class="font-heading text-lg font-bold text-brand-green">Add a user</h2>
    <form method="POST" class="mt-3 flex flex-wrap items-end gap-3">
      <label class="grid gap-1">
        <span class="text-xs font-semibold text-brand-ink/60">Username</span>
        <input name="username" autocomplete="off" class={fieldCls} />
      </label>
      <label class="grid gap-1">
        <span class="text-xs font-semibold text-brand-ink/60">Password</span>
        <input name="password" type="password" autocomplete="new-password" class={fieldCls} />
      </label>
      <button type="submit" name="action" value="add"
        class="rounded-full bg-brand-gold px-5 py-2.5 text-sm font-bold text-brand-green-700 hover:bg-brand-gold-300">
        Add user
      </button>
    </form>
  </div>
</Admin>
