---
import { getServices } from '../content/site/services';
import { siteContext } from '../lib/runtime';
const { db, opts } = siteContext(Astro);
const services = await getServices(db, opts);
---

<section id="services" class="bg-brand-cream py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p class="font-heading text-sm font-bold uppercase tracking-widest text-brand-gold">What we do</p>
      <h2 class="mt-2 font-heading text-3xl font-extrabold text-brand-green sm:text-4xl">
        Full-service landscaping &amp; hardscaping
      </h2>
      <p class="mt-4 text-base leading-relaxed text-brand-ink/70">
        From design-build to drainage repair, we handle the high-craft work that lifts a property —
        for homeowners, builders and commercial clients across the Austin metro.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => (
        <article class="group overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-black/5 transition hover:-translate-y-1 hover:shadow-xl">
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={s.image}
              alt={s.name}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
            />
          </div>
          <div class="p-6">
            <h3 class="font-heading text-xl font-bold text-brand-green">{s.name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-brand-ink/70">{s.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
