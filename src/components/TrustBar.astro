---
import { getBusiness } from '../content/site/business';
import { siteContext } from '../lib/runtime';
const { db, opts } = siteContext(Astro);
const business = await getBusiness(db, opts);
---

<section aria-label="At a glance" class="border-b border-black/5 bg-brand-green text-white">
  <div class="mx-auto grid max-w-7xl grid-cols-1 divide-y divide-white/15 px-5 py-2 sm:grid-cols-3 sm:divide-x sm:divide-y-0 md:px-8">
    <div class="flex items-center justify-center gap-2 px-4 py-3 text-center">
      <span class="font-heading text-xl font-extrabold text-brand-gold-300">{business.yearsInBusiness}</span>
      <span class="text-sm text-white/90">serving Central Texas</span>
    </div>

    <div class="flex items-center justify-center gap-2 px-4 py-3 text-center">
      <span class="text-brand-gold" aria-hidden="true">★★★★★</span>
      <span class="text-sm text-white/90">
        {business.rating.value} rating · {business.rating.count} reviews
      </span>
    </div>

    <div class="flex items-center justify-center px-4 py-3 text-center">
      <span class="text-sm text-white/90">
        {business.serviceArea.slice(0, 5).join(' · ')} &amp; more
      </span>
    </div>
  </div>
</section>
