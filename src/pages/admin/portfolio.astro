---
import Admin from '../../layouts/Admin.astro';
import { getPortfolio, type PortfolioItem, type PortfolioCategory } from '../../content/site/portfolio';
import { getDB } from '../../lib/cf';
import { saveDraft, publish } from '../../lib/db';
import { parseAction, str, num, itemCount, swap, slugify } from '../../lib/editor';
import { uploadImage } from '../../lib/upload';

const CATEGORIES: PortfolioCategory[] = [
  'Hardscape',
  'Design & Build',
  'Drainage',
  'Lawn & Sod',
  'Rock & Specialty',
];

const db = getDB();
let uploadError = '';

if (Astro.request.method === 'POST' && db) {
  const form = await Astro.request.formData();
  const action = parseAction(form.get('action'));
  const count = itemCount(form);
  let items: PortfolioItem[] = [];
  for (let i = 0; i < count; i++) {
    let image = str(form, `image_${i}`);
    const up = await uploadImage(form.get(`image_file_${i}`), 'portfolio');
    if (up.ok) image = up.path;
    else if (up.error !== 'empty') uploadError = `Photo #${i + 1}: ${up.error}`;
    const alt = str(form, `alt_${i}`);
    const cat = str(form, `category_${i}`) as PortfolioCategory;
    items.push({
      id: str(form, `id_${i}`) || slugify(alt) || `item-${i}`,
      image,
      alt,
      category: CATEGORIES.includes(cat) ? cat : 'Hardscape',
      order: i + 1,
    });
  }

  if (action.kind === 'add')
    items.push({ id: '', image: '', alt: '', category: 'Hardscape', order: items.length + 1 });
  else if (action.kind === 'delete' && action.index != null) items.splice(action.index, 1);
  else if (action.kind === 'up' && action.index != null) swap(items, action.index, action.index - 1);
  else if (action.kind === 'down' && action.index != null) swap(items, action.index, action.index + 1);

  if (action.kind === 'save' || action.kind === 'publish') {
    items = items.filter((p) => p.image);
  }
  items.forEach((p, idx) => (p.order = idx + 1));

  await saveDraft(db, 'portfolio', items);
  if (action.kind === 'publish') await publish(db, 'portfolio');

  if (!uploadError) {
    const q = action.kind === 'publish' ? '?published=1' : action.kind === 'save' ? '?saved=1' : '';
    return Astro.redirect(`/admin/portfolio${q}`);
  }
}

const items = await getPortfolio(db, { preview: true });
const saved = Astro.url.searchParams.has('saved');
const published = Astro.url.searchParams.has('published');
const fieldCls = 'rounded-lg border border-black/10 bg-white px-3 py-2.5 text-sm';
---

<Admin title="Edit Portfolio — Goldstar Admin">
  <a href="/admin" class="text-sm font-semibold text-brand-green hover:text-brand-gold">← Dashboard</a>
  <h1 class="mt-2 font-heading text-2xl font-extrabold text-brand-green">Portfolio photos</h1>
  <p class="mt-1 text-sm text-brand-ink/60">{items.length} photos. Upload replaces a photo on save.</p>

  {uploadError && (
    <p class="mt-4 rounded-lg bg-red-50 px-4 py-2 text-sm font-medium text-red-700 ring-1 ring-red-200">{uploadError}</p>
  )}
  {(saved || published) && (
    <p class="mt-4 rounded-lg bg-green-50 px-4 py-2 text-sm font-medium text-green-800 ring-1 ring-green-200">
      {published ? 'Published — live on your site.' : 'Draft saved.'}
    </p>
  )}

  <form method="POST" enctype="multipart/form-data" class="mt-6 grid gap-4">
    <input type="hidden" name="count" value={items.length} />

    {items.map((p, i) => (
      <div class="grid gap-3 rounded-xl bg-white p-4 shadow-sm ring-1 ring-black/5 sm:grid-cols-[120px_1fr]">
        <input type="hidden" name={`id_${i}`} value={p.id} />
        <input type="hidden" name={`image_${i}`} value={p.image} />
        <div>
          {p.image ? (
            <img src={p.image} alt={p.alt} class="h-24 w-full rounded-lg object-cover" />
          ) : (
            <div class="flex h-24 w-full items-center justify-center rounded-lg bg-black/5 text-xs text-brand-ink/40">No photo</div>
          )}
        </div>
        <div class="grid gap-2">
          <div class="flex items-center justify-between gap-2">
            <span class="text-xs font-bold uppercase tracking-wide text-brand-ink/40">#{i + 1}</span>
            <div class="flex gap-1">
              <button type="submit" name="action" value={`up:${i}`} disabled={i === 0}
                class="rounded border border-black/10 px-2 py-1 text-xs disabled:opacity-30">↑</button>
              <button type="submit" name="action" value={`down:${i}`} disabled={i === items.length - 1}
                class="rounded border border-black/10 px-2 py-1 text-xs disabled:opacity-30">↓</button>
              <button type="submit" name="action" value={`delete:${i}`}
                class="rounded border border-red-200 px-2 py-1 text-xs font-semibold text-red-600 hover:bg-red-50">Delete</button>
            </div>
          </div>
          <input name={`alt_${i}`} value={p.alt} placeholder="Describe the photo (alt text)" class={fieldCls} />
          <div class="grid gap-2 sm:grid-cols-2">
            <select name={`category_${i}`} class={fieldCls}>
              {CATEGORIES.map((c) => <option value={c} selected={p.category === c}>{c}</option>)}
            </select>
            <input type="file" name={`image_file_${i}`} accept="image/*" class="text-sm" />
          </div>
        </div>
      </div>
    ))}

    <div>
      <button type="submit" name="action" value="add"
        class="rounded-full border-2 border-dashed border-brand-green/40 px-5 py-2.5 text-sm font-bold text-brand-green hover:bg-brand-green/5">
        + Add photo slot
      </button>
    </div>

    <div class="flex flex-wrap items-center gap-3 border-t border-black/10 pt-5">
      <button type="submit" name="action" value="save"
        class="rounded-full bg-brand-green px-5 py-2.5 text-sm font-bold text-white hover:bg-brand-green-700">Save draft</button>
      <button type="submit" name="action" value="publish"
        class="rounded-full bg-brand-gold px-5 py-2.5 text-sm font-bold text-brand-green-700 hover:bg-brand-gold-300">Publish</button>
      <a href="/?preview=1" target="_blank" class="text-sm font-semibold text-brand-green hover:text-brand-gold">Preview draft ↗</a>
    </div>
  </form>
</Admin>
